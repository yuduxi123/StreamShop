<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- Video player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/live_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:show_buffering="when_playing" />

    <!-- Gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_live_top_gradient" />

    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_live_bottom_gradient" />

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="24dp">

        <ImageButton
            android:id="@+id/live_back_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_circle_overlay"
            android:scaleType="center"
            android:contentDescription="返回" />

        <TextView
            android:id="@+id/live_room_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="直播间" />

        <TextView
            android:id="@+id/live_online_count"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_circle_overlay"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:text="0人在线" />
    </LinearLayout>

    <!-- Danmaku area -->
    <com.bytedance.streamshop.ui.live.DanmakuView
        android:id="@+id/live_danmaku_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="top"
        android:layout_marginTop="72dp"
        android:layout_marginBottom="200dp" />

    <!-- Bottom area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingBottom="8dp">

        <!-- Product carousel -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/live_product_list"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:clipToPadding="false" />

        <!-- Hot value -->
        <TextView
            android:id="@+id/live_hot_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp"
            android:textColor="#FF9500"
            android:textSize="12sp"
            android:text="热度: 0" />

        <!-- Action row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <EditText
                android:id="@+id/live_input"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_round"
                android:hint="说点什么..."
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:textColorHint="#999"
                android:paddingHorizontal="12dp"
                android:paddingVertical="0dp"
                android:maxLines="1"
                android:imeOptions="actionSend"
                android:inputType="text" />

            <ImageButton
                android:id="@+id/live_send_btn"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_send"
                android:background="@drawable/bg_circle_orange"
                android:scaleType="center"
                android:contentDescription="发送" />

            <ImageButton
                android:id="@+id/live_like_btn"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_like_fill"
                android:background="@drawable/bg_circle_overlay"
                android:scaleType="center"
                android:contentDescription="点赞" />
        </LinearLayout>
    </LinearLayout>

    <!-- Coupon notification -->
    <FrameLayout
        android:id="@+id/live_coupon_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="80dp"
        android:visibility="gone" />

</FrameLayout>
