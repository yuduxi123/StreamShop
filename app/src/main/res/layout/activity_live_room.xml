<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- Video player (stays outside overlay container for PIP) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/live_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:show_buffering="when_playing" />

    <!-- All UI overlays in one container — hidden in PIP mode -->
    <FrameLayout
        android:id="@+id/live_overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false">

        <TextView
            android:id="@+id/live_stream_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_circle_overlay"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="直播画面未接入"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/live_top_gradient"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_gravity="top"
            android:background="@drawable/bg_live_top_gradient" />

        <View
            android:id="@+id/live_bottom_gradient"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_live_bottom_gradient" />

        <LinearLayout
            android:id="@+id/live_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_gravity="top"
            android:tag="status_bar_inset"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <LinearLayout
                android:id="@+id/live_anchor_info"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/live_anchor_avatar"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_avatar_placeholder"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImageView" />

                <TextView
                    android:id="@+id/live_anchor_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="主播" />
            </LinearLayout>

            <TextView
                android:id="@+id/live_viewer_count"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:background="@drawable/bg_circle_overlay"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:text="0人在线" />

            <ImageButton
                android:id="@+id/live_pip_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_pip"
                android:background="@drawable/bg_circle_overlay"
                android:scaleType="center"
                android:contentDescription="小窗" />

            <ImageButton
                android:id="@+id/live_exit_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_live_exit"
                android:background="@drawable/bg_circle_overlay"
                android:scaleType="center"
                android:contentDescription="退出" />
        </LinearLayout>

        <com.bytedance.streamshop.ui.live.DanmakuView
            android:id="@+id/live_danmaku_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:layout_marginTop="72dp"
            android:layout_marginBottom="200dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/live_activity_feed"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="190dp"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <LinearLayout
            android:id="@+id/live_bottom_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/live_product_list"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/live_hot_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="4dp"
                android:textColor="#FF9500"
                android:textSize="12sp"
                android:text="热度: 0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp">

                <ImageButton
                    android:id="@+id/live_danmaku_toggle"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/ic_danmaku_on"
                    android:background="@drawable/bg_circle_overlay"
                    android:scaleType="center"
                    android:contentDescription="弹幕开关" />

                <EditText
                    android:id="@+id/live_input"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_round"
                    android:hint="说点什么..."
                    android:textSize="13sp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#999"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="0dp"
                    android:maxLines="1"
                    android:imeOptions="actionSend"
                    android:inputType="text" />

                <ImageButton
                    android:id="@+id/live_send_btn"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_send"
                    android:background="@drawable/bg_circle_orange"
                    android:scaleType="center"
                    android:contentDescription="发送" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/live_coupon_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="80dp"
            android:visibility="gone" />
    </FrameLayout>

</FrameLayout>
