<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/background_dark"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp">

        <ImageButton
            android:id="@+id/create_group_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:scaleType="centerInside"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="发起群聊"
            android:textColor="@color/text_primary_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/create_group_done_btn"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="创建"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:enabled="false" />
    </LinearLayout>

    <EditText
        android:id="@+id/create_group_name_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_edit_text"
        android:hint="群聊名称（可选）"
        android:textColorHint="#BBBBBB"
        android:textColor="@color/text_primary_light"
        android:textSize="14sp"
        android:paddingVertical="14dp"
        android:paddingHorizontal="16dp"
        android:maxLines="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="选择联系人"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/create_group_user_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white" />

    <TextView
        android:id="@+id/create_group_empty"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:gravity="center"
        android:text="你还没有关注任何人"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:visibility="gone" />
</LinearLayout>
