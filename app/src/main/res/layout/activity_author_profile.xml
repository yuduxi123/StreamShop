<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Dark header area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/background_dark"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/author_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="返回"
                    android:src="@drawable/ic_back" />
            </FrameLayout>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/author_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_avatar_placeholder"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                app:strokeWidth="2dp"
                app:strokeColor="#33FFFFFF" />

            <TextView
                android:id="@+id/author_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_primary_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Stats row: 获赞 / 关注 / 粉丝 -->
            <LinearLayout
                android:id="@+id/author_stats_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:id="@+id/author_likes_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/author_likes_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:text="0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:text="获赞" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp"
                    android:background="#33FFFFFF" />

                <LinearLayout
                    android:id="@+id/author_following_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/author_following_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:text="0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:text="关注" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="24dp"
                    android:background="#33FFFFFF" />

                <LinearLayout
                    android:id="@+id/author_followers_stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/author_followers_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:text="0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:text="粉丝" />
                </LinearLayout>
            </LinearLayout>

            <!-- Follow/Unfollow + Message buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/author_follow_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="24dp"
                    android:text="关注"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="14sp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="#FF3B30" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/author_message_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:layout_marginStart="12dp"
                    android:paddingHorizontal="24dp"
                    android:text="发消息"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="14sp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="#007AFF" />
            </LinearLayout>

        </LinearLayout>

        <!-- 2-column video grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/author_video_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:padding="2dp" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/author_empty_videos"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:gravity="center"
            android:text="暂无作品"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
