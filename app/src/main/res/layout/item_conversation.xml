<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false">

    <!-- Action buttons revealed on swipe -->
    <LinearLayout
        android:id="@+id/conv_action_panel"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/conv_action_pin"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:background="#FF9500"
            android:gravity="center"
            android:text="置顶"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/conv_action_delete"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:background="#FF3B30"
            android:gravity="center"
            android:text="删除"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Foreground content (slides left to reveal buttons) -->
    <LinearLayout
        android:id="@+id/conv_foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/conv_avatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:shapeAppearanceOverlay="@style/CircleImageView" />

            <include
                android:id="@+id/conv_group_avatar"
                layout="@layout/view_group_avatar"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/conv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#333333"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/conv_last_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#999999"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center|end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/conv_pin_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pin_indicator"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:text="置顶"
                android:textColor="#FF9500"
                android:textSize="9sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/conv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/conv_unread_badge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_circle_orange"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
