<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp"
    android:background="?attr/selectableItemBackground">

    <!-- Thumbnail -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/manage_item_thumb"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/Rounded8dp" />

    <!-- Name + Price -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/manage_item_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/manage_item_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3B30"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/manage_item_stock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF9500"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp" />
    </LinearLayout>

    <!-- Reorder up -->
    <ImageButton
        android:id="@+id/manage_item_up"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_arrow_up"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="center"
        android:contentDescription="上移" />

    <!-- Reorder down -->
    <ImageButton
        android:id="@+id/manage_item_down"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_arrow_down"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="center"
        android:contentDescription="下移" />

    <!-- Remove -->
    <ImageButton
        android:id="@+id/manage_item_remove"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_close_small"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="center"
        android:layout_marginStart="2dp"
        android:contentDescription="移除" />

</LinearLayout>
