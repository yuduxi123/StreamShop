<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_handle"
        android:layout_marginBottom="16dp" />

    <!-- Product image -->
    <ImageView
        android:id="@+id/product_image"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_avatar_placeholder" />

    <!-- Price row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/product_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF3B30"
            android:textSize="28sp"
            android:textStyle="bold"
            android:text="¥0" />

        <TextView
            android:id="@+id/product_original_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="#999999"
            android:textSize="14sp"
            android:text="¥0"
            android:paddingTop="4dp" />
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/product_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="商品名称" />

    <!-- Description -->
    <TextView
        android:id="@+id/product_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#666666"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:text="商品描述" />

    <!-- Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/product_sales"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#999999"
            android:textSize="13sp"
            android:text="已售 0 件" />

        <TextView
            android:id="@+id/product_stock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#999999"
            android:textSize="13sp"
            android:text="库存 0 件" />
    </LinearLayout>

    <!-- Coupon selection -->
    <LinearLayout
        android:id="@+id/product_coupon_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_comment_input"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="选择优惠券"
            android:textSize="13sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/product_coupon_discount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未选择"
            android:textSize="13sp"
            android:textColor="#FF6B35" />
    </LinearLayout>

    <!-- Collect & Reviews row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/product_collect_btn"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="收藏"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_collect_outline"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:strokeColor="#FFD700" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/product_reviews_btn"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:text="查看评价"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_star_on"
            app:iconSize="16dp"
            app:iconGravity="textStart"
            app:strokeColor="#FFD700" />
    </LinearLayout>

    <!-- Buy now button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/product_buy_now_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:text="立即购买"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:cornerRadius="24dp"
        app:backgroundTint="#FF6B35" />

    <!-- Add to cart button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/product_add_cart_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:text="加入购物车"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:cornerRadius="24dp"
        app:backgroundTint="#FF3B30" />

</LinearLayout>

</androidx.core.widget.NestedScrollView>
