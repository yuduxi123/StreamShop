<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clipChildren="false">

    <!-- Action buttons revealed on swipe -->
    <LinearLayout
        android:id="@+id/order_action_panel"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/order_action_btn1"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:background="#4CAF50"
            android:gravity="center"
            android:text="已收货"
            android:textColor="@color/text_primary_dark"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/order_action_btn2"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:background="#FF9500"
            android:gravity="center"
            android:text="催单"
            android:textColor="@color/text_primary_dark"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Foreground content (slides left to reveal buttons) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/order_foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="1dp"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Status header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/order_item_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:text="订单号" />
                <TextView
                    android:id="@+id/order_item_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FF3B30"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:text="待支付" />
            </LinearLayout>

            <!-- Product items -->
            <LinearLayout
                android:id="@+id/order_item_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <!-- Amount -->
            <TextView
                android:id="@+id/order_item_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_gravity="end"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:text="合计：¥0.00" />

            <!-- Actions -->
            <LinearLayout
                android:id="@+id/order_item_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="end"
                android:orientation="horizontal" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
