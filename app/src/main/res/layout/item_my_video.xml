<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@android:color/white"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/my_video_cover"
        android:layout_width="80dp"
        android:layout_height="100dp"
        android:scaleType="centerCrop"
        android:background="#F0F0F0"
        android:src="@drawable/ic_avatar_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/my_video_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@android:color/black"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/my_video_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="#F5F5F5"
                android:textColor="#999999" />

            <TextView
                android:id="@+id/my_video_views"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="12sp"
                android:textColor="#999999" />

            <TextView
                android:id="@+id/my_video_likes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="12sp"
                android:textColor="#999999" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/my_video_edit"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="编辑"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:background="#1a1a2e" />

            <TextView
                android:id="@+id/my_video_delete"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="删除"
                android:textSize="12sp"
                android:textColor="#FF4D4F"
                android:layout_marginStart="8dp"
                android:background="#FFF2F0" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
