<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="1dp"
    android:clipChildren="false">

    <!-- Action buttons revealed on swipe -->
    <LinearLayout
        android:id="@+id/my_video_action_panel"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/my_video_action_edit"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:background="#FF9500"
            android:gravity="center"
            android:text="编辑"
            android:textColor="@color/text_primary_dark"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/my_video_action_delete"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:background="#FF3B30"
            android:gravity="center"
            android:text="删除"
            android:textColor="@color/text_primary_dark"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Foreground content (slides left to reveal buttons) -->
    <LinearLayout
        android:id="@+id/my_video_foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/my_video_cover"
            android:layout_width="80dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:background="#F0F0F0"
            android:src="@drawable/ic_avatar_placeholder" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/my_video_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@android:color/black"
                android:maxLines="2"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/my_video_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:background="@color/background_light"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/my_video_views"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/my_video_likes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
