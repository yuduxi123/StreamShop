<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:background="@color/background_dark"
        android:paddingHorizontal="4dp">

        <ImageButton
            android:id="@+id/my_videos_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="我的视频"
            android:textSize="18sp"
            android:textColor="@color/text_primary_dark"
            android:textStyle="bold" />

        <Button
            android:id="@+id/my_videos_create"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:text="+ 新建视频"
            android:textSize="13sp"
            android:backgroundTint="#1a1a2e"
            android:textColor="@android:color/white"
            android:paddingHorizontal="14dp" />
    </LinearLayout>

    <!-- Video list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/my_videos_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/my_videos_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="暂无视频\n点击右上角新建"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/my_videos_loading"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:visibility="gone" />

</LinearLayout>
