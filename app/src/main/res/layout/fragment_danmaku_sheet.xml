<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp"
    android:background="#1A1A1A">

    <!-- Danmaku on/off toggle (far left) -->
    <ImageView
        android:id="@+id/danmaku_toggle_btn"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_danmaku_toggle"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <!-- Input fills the rest -->
    <EditText
        android:id="@+id/danmaku_input"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:hint="发一条友好的弹幕吧"
        android:textColor="@android:color/white"
        android:textColorHint="#666666"
        android:textSize="14sp"
        android:background="@drawable/bg_danmaku_input"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:maxLines="1"
        android:singleLine="true"
        android:imeOptions="actionSend" />

</LinearLayout>
