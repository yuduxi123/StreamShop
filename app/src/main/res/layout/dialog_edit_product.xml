<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/dialog_product_name"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_edit_text"
        android:paddingHorizontal="12dp"
        android:textSize="14sp"
        android:hint="商品名称"
        android:singleLine="true" />

    <EditText
        android:id="@+id/dialog_product_price"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:paddingHorizontal="12dp"
        android:textSize="14sp"
        android:hint="价格 (¥)"
        android:inputType="numberDecimal"
        android:singleLine="true" />

    <EditText
        android:id="@+id/dialog_product_original_price"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:paddingHorizontal="12dp"
        android:textSize="14sp"
        android:hint="原价/划线价（选填）"
        android:inputType="numberDecimal"
        android:singleLine="true" />

    <EditText
        android:id="@+id/dialog_product_stock"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:paddingHorizontal="12dp"
        android:textSize="14sp"
        android:hint="库存（件数）"
        android:inputType="number"
        android:singleLine="true" />

    <EditText
        android:id="@+id/dialog_product_timestamp"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:paddingHorizontal="12dp"
        android:textSize="14sp"
        android:hint="绑定时间点（分:秒，如 1:30）"
        android:singleLine="true" />

</LinearLayout>
