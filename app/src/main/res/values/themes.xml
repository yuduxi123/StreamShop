<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.StreamShop" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Theme.StreamShop" parent="Base.Theme.StreamShop" />

    <style name="Theme.StreamShop.Splash" parent="Theme.StreamShop" />

    <style name="Theme.StreamShop.Crop" parent="Theme.Material3.DayNight" />

    <!-- Bottom navigation text styles -->
    <style name="BottomNavTextActive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="BottomNavTextInactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">13sp</item>
    </style>
</resources>
